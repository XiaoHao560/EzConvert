<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="?android:attr/colorBackground"
     android:orientation="vertical">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:orientation="vertical"
         android:id="@+id/title_container">

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
         android:layout_height="0dp"
         android:layout_width="match_parent"
         android:fillViewport="true"
         android:paddingVertical="8dp"
         android:clipChildren="false"
         android:clipToPadding="false"
         android:paddingHorizontal="16dp"
         android:layout_weight="1"
         android:id="@+id/scroll_content">

        <LinearLayout
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:orientation="vertical">

            <com.google.android.material.card.MaterialCardView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:layout_marginBottom="8dp"
                 app:cardElevation="0dp"
                 android:backgroundTint="?attr/colorSurfaceContainerLow"
                 app:strokeWidth="0dp"
                 app:cardCornerRadius="16dp"
                 android:id="@+id/device_info_card">

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:orientation="vertical">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:background="?attr/selectableItemBackground"
                         android:gravity="center_vertical"
                         android:clickable="true"
                         android:padding="16dp"
                         android:orientation="horizontal"
                         android:focusable="true"
                         android:id="@+id/device_info_header">

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             android:orientation="vertical"
                             android:layout_weight="1">

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:textSize="16sp"
                                 android:textColor="?attr/colorOnSurface"
                                 android:text="设备信息"
                                 android:textStyle="bold" />

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:textSize="12sp"
                                 android:textColor="?attr/colorOnSurfaceVariant"
                                 android:layout_marginTop="2dp"
                                 android:id="@+id/device_info_summary"
                                 android:text="点击查看详情" />

                        </LinearLayout>

                        <ImageView
                             android:layout_height="24dp"
                             android:layout_width="24dp"
                             android:src="@drawable/ic_arrow_down"
                             android:rotation="-90"
                             app:tint="?attr/colorOnSurfaceVariant"
                             android:id="@+id/device_info_expand_icon" />

                    </LinearLayout>

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:visibility="gone"
                         android:padding="16dp"
                         android:orientation="vertical"
                         android:id="@+id/device_info_content">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="14sp"
                             android:textColor="?attr/colorOnSurface"
                             android:text="设备信息"
                             android:textStyle="bold" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="13sp"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="8dp"
                             android:id="@+id/device_name"
                             android:text="设备名称: " />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="13sp"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="4dp"
                             android:id="@+id/device_model"
                             android:text="设备型号: " />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="13sp"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="4dp"
                             android:id="@+id/android_version"
                             android:text="安卓版本: " />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="13sp"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="4dp"
                             android:id="@+id/system_version"
                             android:text="系统版本: " />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="13sp"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="4dp"
                             android:id="@+id/cpu_arch"
                             android:text="CPU架构: " />

                        <com.google.android.material.divider.MaterialDivider
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:layout_marginVertical="12dp" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="14sp"
                             android:textColor="?attr/colorOnSurface"
                             android:text="应用信息"
                             android:textStyle="bold" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="13sp"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="8dp"
                             android:id="@+id/app_version_name"
                             android:text="版本名称: " />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="13sp"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="4dp"
                             android:id="@+id/app_version_code"
                             android:text="版本号: " />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:textSize="13sp"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="4dp"
                             android:id="@+id/app_commit_hash"
                             android:text="Commit: " />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:layout_marginBottom="8dp"
                 app:cardElevation="0dp"
                 android:backgroundTint="?attr/colorSurfaceContainerLow"
                 app:strokeWidth="0dp"
                 app:cardCornerRadius="16dp"
                 android:id="@+id/app_log_card">

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:orientation="vertical">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:background="?attr/selectableItemBackground"
                         android:gravity="center_vertical"
                         android:clickable="true"
                         android:padding="16dp"
                         android:orientation="horizontal"
                         android:focusable="true"
                         android:id="@+id/app_log_header">

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             android:orientation="vertical"
                             android:layout_weight="1">

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:textSize="16sp"
                                 android:textColor="?attr/colorOnSurface"
                                 android:text="应用日志"
                                 android:textStyle="bold" />

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:textSize="12sp"
                                 android:textColor="?attr/colorOnSurfaceVariant"
                                 android:layout_marginTop="2dp"
                                 android:id="@+id/app_log_count_text"
                                 android:text="共 0 条" />

                        </LinearLayout>

                        <ImageView
                             android:layout_height="24dp"
                             android:layout_width="24dp"
                             android:src="@drawable/ic_arrow_down"
                             android:rotation="0"
                             app:tint="?attr/colorOnSurfaceVariant"
                             android:id="@+id/app_log_expand_icon" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:visibility="visible"
                         android:maxHeight="350dp"
                         android:minHeight="120dp"
                         android:padding="6dp"
                         android:clipToPadding="false"
                         android:id="@+id/app_log_recycler_view" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 app:cardElevation="0dp"
                 android:backgroundTint="?attr/colorSurfaceContainerLow"
                 app:strokeWidth="0dp"
                 app:cardCornerRadius="16dp"
                 android:id="@+id/ffmpeg_log_card">

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:orientation="vertical">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:background="?attr/selectableItemBackground"
                         android:gravity="center_vertical"
                         android:clickable="true"
                         android:padding="16dp"
                         android:orientation="horizontal"
                         android:focusable="true"
                         android:id="@+id/ffmpeg_log_header">

                        <LinearLayout
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             android:orientation="vertical"
                             android:layout_weight="1">

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:textSize="16sp"
                                 android:textColor="?attr/colorOnSurface"
                                 android:text="FFmpeg日志"
                                 android:textStyle="bold" />

                            <TextView
                                 android:layout_height="wrap_content"
                                 android:layout_width="wrap_content"
                                 android:textSize="12sp"
                                 android:textColor="?attr/colorOnSurfaceVariant"
                                 android:layout_marginTop="2dp"
                                 android:id="@+id/ffmpeg_log_count_text"
                                 android:text="共 0 条" />

                        </LinearLayout>

                        <ImageView
                             android:layout_height="24dp"
                             android:layout_width="24dp"
                             android:src="@drawable/ic_arrow_down"
                             android:rotation="0"
                             app:tint="?attr/colorOnSurfaceVariant"
                             android:id="@+id/ffmpeg_log_expand_icon" />

                    </LinearLayout>

                    <androidx.recyclerview.widget.RecyclerView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:visibility="visible"
                         android:maxHeight="350dp"
                         android:minHeight="120dp"
                         android:padding="6dp"
                         android:clipToPadding="false"
                         android:id="@+id/ffmpeg_log_recycler_view" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:background="?attr/colorSurfaceContainerHighest"
         android:padding="16dp"
         android:orientation="horizontal"
         android:id="@+id/bottom_buttons">

        <com.google.android.material.button.MaterialButton
             android:layout_height="48dp"
             android:layout_width="48dp"
             app:icon="@drawable/backup"
             android:contentDescription="导出日志"
             android:tooltipText="导出日志"
             app:iconSize="24dp"
             style="@style/Widget.Material3.Button.IconButton.Filled"
             app:iconPadding="0dp"
             android:id="@+id/btn_export_log"
             app:iconGravity="textStart" />

        <View
             android:layout_height="0dp"
             android:layout_width="0dp"
             android:layout_weight="1" />

        <com.google.android.material.button.MaterialButton
             android:layout_height="48dp"
             android:layout_width="48dp"
             app:icon="@drawable/delete_outline"
             android:contentDescription="清空日志"
             android:tooltipText="清空日志"
             app:iconSize="24dp"
             style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
             app:iconPadding="0dp"
             android:id="@+id/btn_clear_log"
             app:iconGravity="textStart" />

        <com.google.android.material.button.MaterialButton
             android:layout_height="48dp"
             android:layout_width="48dp"
             app:icon="@drawable/vector_arrange_below"
             android:contentDescription="复制日志"
             android:tooltipText="复制日志"
             app:iconSize="24dp"
             style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
             app:iconPadding="0dp"
             android:layout_marginStart="8dp"
             android:id="@+id/btn_copy_log"
             app:iconGravity="textStart" />

    </LinearLayout>

</LinearLayout>