<?xml version="1.0" encoding="utf-8"?>
<ScrollView
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="?attr/colorSurfaceContainerLowest"
     android:scrollbarStyle="outsideOverlay"
     android:fadeScrollbars="true">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:padding="16dp"
         android:orientation="vertical"
         android:id="@+id/scroll_content">

        <com.google.android.material.appbar.MaterialToolbar
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             android:background="@android:color/transparent"
             app:navigationIconTint="?attr/colorOnSurfaceVariant"
             app:title="EzConvert 媒体转换器"
             app:titleCentered="true"
             app:titleTextColor="?attr/colorPrimary"
             app:navigationIcon="@drawable/round_menu"
             style="@style/Widget.Material3.Toolbar.Surface"
             app:navigationContentDescription="@string/tooltip_menu"
             android:id="@+id/title_container">

        </com.google.android.material.appbar.MaterialToolbar>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="24dp"
             android:gravity="center"
             android:textSize="12sp"
             android:fontFamily="?attr/textAppearanceLabelMedium"
             android:textColor="?attr/colorOnSurfaceVariant"
             android:id="@+id/version_text"
             android:text="EzConvert v0.0.0 | FFmpegKit: 6.0-2" />

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/status_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:id="@+id/status_text"
                     android:text="请选择要处理的媒体文件" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:trackColor="?attr/colorSurfaceContainerHighest"
                     app:trackCornerRadius="2dp"
                     style="@style/Widget.Material3.LinearProgressIndicator"
                     android:progress="0"
                     app:trackThickness="4dp"
                     android:id="@+id/progress_bar"
                     app:indicatorColor="?attr/colorPrimary" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:gravity="center"
                     android:textSize="12sp"
                     android:fontFamily="?attr/textAppearanceLabelSmall"
                     android:textColor="?attr/colorOnSurfaceVariant"
                     android:id="@+id/progress_text"
                     android:text="进度: 0%" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:visibility="gone"
                     app:icon="@drawable/round_close"
                     android:backgroundTint="?attr/colorErrorContainer"
                     style="@style/Widget.Material3.Button.TonalButton.Icon"
                     android:layout_marginTop="16dp"
                     android:id="@+id/cancel_btn"
                     android:text="取消操作"
                     app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/file_selection_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:text="文件选择" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     app:icon="@drawable/round_folder"
                     style="@style/Widget.Material3.Button.Icon"
                     android:id="@+id/select_file_btn"
                     android:text="选择媒体文件"
                     app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/options_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:text="转换选项" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="12dp"
                     android:orientation="vertical">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="4dp"
                         android:textSize="12sp"
                         android:textColor="?attr/colorOnSurfaceVariant"
                         android:text="视频格式" />

                    <com.google.android.material.textfield.TextInputLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         app:hintEnabled="false"
                         app:boxStrokeColor="?attr/colorOutline"
                         app:boxStrokeWidthFocused="2dp"
                         app:boxBackgroundColor="?attr/colorSurface"
                         style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                         app:boxStrokeWidth="1dp">

                        <AutoCompleteTextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:paddingVertical="12dp"
                             android:textColor="?attr/colorOnSurface"
                             android:inputType="none"
                             android:id="@+id/video_format_spinner" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="12dp"
                     android:orientation="vertical">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="4dp"
                         android:textSize="12sp"
                         android:textColor="?attr/colorOnSurfaceVariant"
                         android:text="音频格式" />

                    <com.google.android.material.textfield.TextInputLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         app:hintEnabled="false"
                         app:boxStrokeColor="?attr/colorOutline"
                         app:boxStrokeWidthFocused="2dp"
                         app:boxBackgroundColor="?attr/colorSurface"
                         style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                         app:boxStrokeWidth="1dp">

                        <AutoCompleteTextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:paddingVertical="12dp"
                             android:textColor="?attr/colorOnSurface"
                             android:inputType="none"
                             android:id="@+id/audio_format_spinner" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:orientation="vertical">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="4dp"
                         android:textSize="12sp"
                         android:textColor="?attr/colorOnSurfaceVariant"
                         android:text="质量设置" />

                    <com.google.android.material.textfield.TextInputLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         app:hintEnabled="false"
                         app:boxStrokeColor="?attr/colorOutline"
                         app:boxStrokeWidthFocused="2dp"
                         app:boxBackgroundColor="?attr/colorSurface"
                         style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                         app:boxStrokeWidth="1dp">

                        <AutoCompleteTextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:paddingVertical="12dp"
                             android:textColor="?attr/colorOnSurface"
                             android:inputType="none"
                             android:id="@+id/quality_spinner" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     app:dividerColor="?attr/colorOutlineVariant"
                     app:dividerThickness="1dp" />

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     android:orientation="vertical">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="4dp"
                         android:textSize="12sp"
                         android:textColor="?attr/colorOnSurfaceVariant"
                         android:text="@string/volume_setting" />

                    <com.google.android.material.textfield.TextInputLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         app:hintEnabled="false"
                         app:boxStrokeColor="?attr/colorOutline"
                         app:boxStrokeWidthFocused="2dp"
                         app:boxBackgroundColor="?attr/colorSurface"
                         style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                         app:boxStrokeWidth="1dp">

                        <AutoCompleteTextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:paddingVertical="12dp"
                             android:textColor="?attr/colorOnSurface"
                             android:inputType="none"
                             android:id="@+id/volume_spinner" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="4dp"
                     android:visibility="gone"
                     android:orientation="vertical"
                     android:id="@+id/custom_volume_layout">

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="8dp"
                         android:gravity="center_vertical"
                         android:orientation="horizontal">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="0dp"
                             android:gravity="center_vertical"
                             android:textSize="14sp"
                             android:fontFamily="?attr/textAppearanceLabelMedium"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_weight="1"
                             android:text="音量大小" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="wrap_content"
                             android:fontFamily="?attr/textAppearanceLabelLarge"
                             android:textColor="?attr/colorPrimary"
                             android:id="@+id/volume_percent_text"
                             android:text="100%"
                             android:textStyle="bold" />

                    </LinearLayout>

                    <com.google.android.material.slider.Slider
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         app:thumbColor="?attr/colorPrimary"
                         app:haloColor="?attr/colorPrimaryContainer"
                         app:tickVisible="false"
                         android:valueTo="200"
                         app:trackColorActive="?attr/colorPrimary"
                         android:value="100"
                         app:trackColorInactive="?attr/colorSurfaceContainerHighest"
                         android:valueFrom="0"
                         app:trackHeight="4dp"
                         android:id="@+id/volume_seekbar" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/video_processing_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:text="视频处理" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/round_transform"
                     style="@style/Widget.Material3.Button.Icon"
                     android:id="@+id/convert_btn"
                     android:text="转换格式"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/compress"
                     style="@style/Widget.Material3.Button.TonalButton.Icon"
                     android:id="@+id/compress_btn"
                     android:text="压缩视频"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/round_audiotrack"
                     style="@style/Widget.Material3.Button.TonalButton.Icon"
                     android:id="@+id/extract_audio_btn"
                     android:text="提取音频"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/round_content_cut"
                     style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                     android:id="@+id/cut_video_btn"
                     android:text="裁剪视频"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     app:icon="@drawable/round_camera_alt"
                     style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                     android:id="@+id/screenshot_btn"
                     android:text="视频截图"
                     app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/audio_processing_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:text="音频处理" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/round_audiotrack"
                     style="@style/Widget.Material3.Button.Icon"
                     android:id="@+id/convert_audio_btn"
                     android:text="转换音频格式"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     app:icon="@drawable/round_audiotrack"
                     style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                     android:id="@+id/cut_audio_btn"
                     android:text="裁剪音频"
                     app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:textSize="12sp"
             android:fontFamily="?attr/textAppearanceLabelSmall"
             android:textColor="?attr/colorOnSurfaceVariant"
             android:layout_marginTop="8dp"
             android:text="提示: 输出文件将保存在下载文件夹中" />

    </LinearLayout>

</ScrollView>