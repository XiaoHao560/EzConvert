<?xml version="1.0" encoding="utf-8"?>
<ScrollView
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="?attr/colorSurfaceContainerLowest"
     android:scrollbarStyle="outsideOverlay"
     android:fadeScrollbars="true">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:padding="16dp"
         android:orientation="vertical"
         android:id="@+id/scroll_content">

        <com.google.android.material.appbar.MaterialToolbar
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             android:background="@android:color/transparent"
             app:navigationIconTint="?attr/colorOnSurfaceVariant"
             app:title="@string/app_title"
             app:titleCentered="true"
             app:titleTextColor="?attr/colorPrimary"
             app:titleMarginTop="17dp"
             app:navigationIcon="@drawable/round_menu"
             style="@style/Widget.Material3.Toolbar.Surface"
             app:navigationContentDescription="@string/tooltip_menu"
             android:id="@+id/title_container">

        </com.google.android.material.appbar.MaterialToolbar>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="24dp"
             android:gravity="center"
             android:textSize="12sp"
             android:fontFamily="?attr/textAppearanceLabelMedium"
             android:textColor="?attr/colorOnSurfaceVariant"
             android:id="@+id/version_text"
             android:text="@string/version_text_default" />

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/status_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:id="@+id/status_text"
                     android:text="@string/status_select_file" />

                <com.google.android.material.progressindicator.LinearProgressIndicator
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:trackColor="?attr/colorSurfaceContainerHighest"
                     app:trackCornerRadius="2dp"
                     style="@style/Widget.Material3.LinearProgressIndicator"
                     android:progress="0"
                     app:trackThickness="4dp"
                     android:id="@+id/progress_bar"
                     app:indicatorColor="?attr/colorPrimary" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:gravity="center"
                     android:textSize="12sp"
                     android:fontFamily="?attr/textAppearanceLabelSmall"
                     android:textColor="?attr/colorOnSurfaceVariant"
                     android:id="@+id/progress_text"
                     android:text="@string/progress_default" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:visibility="gone"
                     app:icon="@drawable/round_close"
                     android:backgroundTint="?attr/colorErrorContainer"
                     style="@style/Widget.Material3.Button.TonalButton.Icon"
                     android:layout_marginTop="16dp"
                     android:id="@+id/cancel_btn"
                     android:text="@string/btn_cancel_ffmpeg"
                     app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/file_selection_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:text="@string/section_file_selection" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     app:icon="@drawable/round_folder"
                     style="@style/Widget.Material3.Button.Icon"
                     android:id="@+id/select_file_btn"
                     android:text="@string/btn_select_file"
                     app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/video_processing_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:text="@string/section_video_processing" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/round_transform"
                     style="@style/Widget.Material3.Button.Icon"
                     android:id="@+id/convert_btn"
                     android:text="@string/btn_convert_format"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/compress"
                     style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                     android:id="@+id/compress_btn"
                     android:text="@string/btn_compress_video"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/round_audiotrack"
                     style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                     android:id="@+id/extract_audio_btn"
                     android:text="@string/btn_extract_audio"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/round_content_cut"
                     style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                     android:id="@+id/cut_video_btn"
                     android:text="@string/btn_cut_video"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     app:icon="@drawable/round_camera_alt"
                     style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                     android:id="@+id/screenshot_btn"
                     android:text="@string/btn_screenshot"
                     app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp"
             android:id="@+id/audio_processing_card">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="16dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="16sp"
                     android:fontFamily="?attr/textAppearanceTitleMedium"
                     android:textColor="?attr/colorOnSurface"
                     android:text="@string/section_audio_processing" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     app:icon="@drawable/round_audiotrack"
                     style="@style/Widget.Material3.Button.Icon"
                     android:id="@+id/convert_audio_btn"
                     android:text="@string/btn_convert_audio"
                     app:iconGravity="textStart" />

                <Button
                     android:layout_height="48dp"
                     android:layout_width="match_parent"
                     app:icon="@drawable/round_audiotrack"
                     style="@style/Widget.Material3.Button.OutlinedButton.Icon"
                     android:id="@+id/cut_audio_btn"
                     android:text="@string/btn_cut_audio"
                     app:iconGravity="textStart" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:textSize="12sp"
             android:fontFamily="?attr/textAppearanceLabelSmall"
             android:textColor="?attr/colorOnSurfaceVariant"
             android:layout_marginTop="8dp"
             android:text="@string/hint_output_location" />

    </LinearLayout>

</ScrollView>
