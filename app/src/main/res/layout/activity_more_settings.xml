<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    android:layout_width="match_parent"
    android:background="?attr/colorSurfaceContainerLowest"
    android:scrollbarStyle="outsideOverlay"
    android:fadeScrollbars="true">

    <LinearLayout
        android:layout_height="wrap_content"
        android:layout_width="match_parent"
        android:padding="16dp"
        android:orientation="vertical"
        android:id="@+id/scroll_content">

        <com.google.android.material.appbar.MaterialToolbar
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:layout_marginBottom="16dp"
            android:background="@android:color/transparent"
            app:navigationIconTint="?attr/colorOnSurfaceVariant"
            app:title="通用设置"
            app:titleCentered="true"
            app:titleTextColor="?attr/colorPrimary"
            app:navigationIcon="@drawable/round_arrow_back"
            app:navigationContentDescription="@string/tooltip_back"
            style="@style/Widget.Material3.Toolbar.Surface"
            android:id="@+id/title_container" />

        <com.google.android.material.card.MaterialCardView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:layout_marginBottom="12dp"
            app:strokeColor="?attr/colorOutline"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/transparent"
            style="@style/Widget.Material3.CardView.Outlined"
            app:cardCornerRadius="12dp"
            android:id="@+id/run_log_card">

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_height="72dp"
                    android:layout_width="match_parent"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp"
                    android:background="?attr/selectableItemBackground"
                    android:gravity="center_vertical"
                    android:clickable="true"
                    android:orientation="horizontal"
                    android:focusable="true"
                    android:id="@+id/item_run_log">

                    <FrameLayout
                        android:layout_height="40dp"
                        android:layout_width="40dp"
                        android:layout_marginEnd="16dp"
                        android:background="@drawable/circle_background_primary_container">

                        <ImageView
                            android:layout_height="24dp"
                            android:layout_width="24dp"
                            android:layout_gravity="center"
                            android:src="@drawable/bug_outline"
                            app:tint="?attr/colorPrimary" />

                    </FrameLayout>

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="0dp"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_weight="1"
                        android:text="@string/run_log" />

                    <ImageView
                        android:layout_height="24dp"
                        android:layout_width="24dp"
                        android:src="@drawable/round_arrow_forward"
                        app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    app:dividerColor="?attr/colorOutlineVariant"
                    app:dividerThickness="1dp" />

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingExtra="4dp"
                    android:text="查看应用运行日志和错误信息，便于问题排查" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:layout_marginBottom="12dp"
            app:strokeColor="?attr/colorOutline"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/transparent"
            style="@style/Widget.Material3.CardView.Outlined"
            app:cardCornerRadius="12dp"
            android:id="@+id/theme_settings_card">

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_marginBottom="16dp"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"
                        android:text="主题设置" />

                    <LinearLayout
                        android:layout_height="72dp"
                        android:layout_width="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:id="@+id/item_theme_system">

                        <FrameLayout
                            android:layout_height="40dp"
                            android:layout_width="40dp"
                            android:layout_marginEnd="16dp"
                            android:background="@drawable/circle_background_primary_container">

                            <ImageView
                                android:layout_height="24dp"
                                android:layout_width="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/round_brightness_auto"
                                app:tint="?attr/colorPrimary" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:orientation="vertical"
                            android:layout_weight="1">

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurface"
                                android:text="跟随系统" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:text="根据系统设置自动切换深浅主题" />

                        </LinearLayout>

                        <RadioButton
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/radio_theme_system"
                            android:clickable="false"
                            android:focusable="false" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_height="72dp"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:id="@+id/item_theme_light">

                        <FrameLayout
                            android:layout_height="40dp"
                            android:layout_width="40dp"
                            android:layout_marginEnd="16dp"
                            android:background="@drawable/circle_background_primary_container">

                            <ImageView
                                android:layout_height="24dp"
                                android:layout_width="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/round_brightness_high"
                                app:tint="?attr/colorPrimary" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:orientation="vertical"
                            android:layout_weight="1">

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurface"
                                android:text="浅色模式" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:text="始终使用浅色主题" />

                        </LinearLayout>

                        <RadioButton
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/radio_theme_light"
                            android:clickable="false"
                            android:focusable="false" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_height="72dp"
                        android:layout_width="match_parent"
                        android:layout_marginTop="8dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:id="@+id/item_theme_dark">

                        <FrameLayout
                            android:layout_height="40dp"
                            android:layout_width="40dp"
                            android:layout_marginEnd="16dp"
                            android:background="@drawable/circle_background_primary_container">

                            <ImageView
                                android:layout_height="24dp"
                                android:layout_width="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/round_bedtime"
                                app:tint="?attr/colorPrimary" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:orientation="vertical"
                            android:layout_weight="1">

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurface"
                                android:text="深色模式" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:text="始终使用深色主题" />

                        </LinearLayout>

                        <RadioButton
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/radio_theme_dark"
                            android:clickable="false"
                            android:focusable="false" />

                    </LinearLayout>

                    <com.google.android.material.divider.MaterialDivider
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_marginTop="16dp"
                        app:dividerColor="?attr/colorOutlineVariant"
                        app:dividerThickness="1dp" />

                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_marginTop="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true"
                        android:focusable="true"
                        android:id="@+id/item_dynamic_color">

                        <FrameLayout
                            android:layout_height="40dp"
                            android:layout_width="40dp"
                            android:layout_marginEnd="16dp"
                            android:background="@drawable/circle_background_primary_container">

                            <ImageView
                                android:layout_height="24dp"
                                android:layout_width="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/round_palette"
                                app:tint="?attr/colorPrimary" />

                        </FrameLayout>

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:orientation="vertical"
                            android:layout_weight="1">

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurface"
                                android:text="自动取色" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:text="根据系统壁纸颜色动态生成主题色调（Material You）" />

                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/dynamic_color_switch" />

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    app:dividerColor="?attr/colorOutlineVariant"
                    app:dividerThickness="1dp" />

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingExtra="2dp"
                    android:text="选择应用主题显示模式。跟随系统将根据设备的系统设置自动在浅色和深色主题间切换。自动取色功能需要 Android 12 及以上系统支持，开启后将根据壁纸颜色动态调整应用主题色调" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:layout_marginBottom="12dp"
            app:strokeColor="?attr/colorOutline"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/transparent"
            style="@style/Widget.Material3.CardView.Outlined"
            app:cardCornerRadius="12dp"
            android:id="@+id/notification_settings_card">

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_marginBottom="16dp"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"
                        android:text="通知设置" />

                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:orientation="vertical"
                            android:layout_weight="1">

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurface"
                                android:text="启用通知" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:text="显示转换进度和完成提示" />

                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/notification_switch" />

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    app:dividerColor="?attr/colorOutlineVariant"
                    app:dividerThickness="1dp" />

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingExtra="2dp"
                    android:text="开启后，转换过程中会显示进度通知，完成后会显示成功或失败提示。需要系统通知权限" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:layout_marginBottom="12dp"
            app:strokeColor="?attr/colorOutline"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/transparent"
            style="@style/Widget.Material3.CardView.Outlined"
            app:cardCornerRadius="12dp"
            android:id="@+id/update_settings_card">

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_marginBottom="16dp"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"
                        android:text="更新设置" />

                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_marginBottom="0dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:orientation="vertical"
                            android:layout_weight="1">

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurface"
                                android:text="自动检测更新" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:text="启动时自动检查版本更新" />

                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/auto_update_switch" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="16dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurface"
                                android:text="检测测试版更新" />

                            <TextView
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:text="包含预发布版本，可能不稳定" />

                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:id="@+id/prerelease_switch" />

                    </LinearLayout>
                    
                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="vertical"
                        android:id="@+id/frequency_layout">

                        <com.google.android.material.divider.MaterialDivider
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            app:dividerColor="?attr/colorOutlineVariant"
                            app:dividerThickness="1dp"
                            android:layout_marginBottom="16dp" />

                        <TextView
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            android:layout_marginBottom="12dp"
                            android:textSize="14sp"
                            android:fontFamily="sans-serif-medium"
                            android:textColor="?attr/colorOnSurface"
                            android:text="检测频率" />

                        <com.google.android.material.textfield.TextInputLayout
                            android:layout_height="wrap_content"
                            android:layout_width="match_parent"
                            app:hintEnabled="false"
                            app:boxStrokeColor="?attr/colorOutline"
                            app:boxStrokeWidthFocused="2dp"
                            app:boxBackgroundColor="?attr/colorSurface"
                            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                            app:boxStrokeWidth="1dp">

                            <com.google.android.material.textfield.MaterialAutoCompleteTextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:paddingVertical="12dp"
                                android:textColor="?attr/colorOnSurface"
                                android:inputType="none"
                                android:id="@+id/frequency_spinner" />

                        </com.google.android.material.textfield.TextInputLayout>

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    app:dividerColor="?attr/colorOutlineVariant"
                    app:dividerThickness="1dp" />

                <TextView
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:textSize="12sp"
                    android:fontFamily="sans-serif"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:lineSpacingExtra="2dp"
                    android:text="开启自动检测后，应用会根据您选择的频率自动检查版本更新。关闭后，您仍可在关于页面手动检查更新" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:layout_height="wrap_content"
            android:layout_width="match_parent"
            android:layout_marginBottom="12dp"
            app:strokeColor="?attr/colorOutline"
            app:cardElevation="0dp"
            app:strokeWidth="1dp"
            app:cardBackgroundColor="@android:color/transparent"
            style="@style/Widget.Material3.CardView.Outlined"
            app:cardCornerRadius="12dp"
            android:id="@+id/firebase_settings_card">

            <LinearLayout
                android:layout_height="wrap_content"
                android:layout_width="match_parent"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    android:padding="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:layout_marginBottom="16dp"
                        android:textSize="16sp"
                        android:fontFamily="sans-serif-medium"
                        android:textColor="?attr/colorOnSurface"
                        android:text="隐私与数据" />

                    <LinearLayout
                        android:layout_height="wrap_content"
                        android:layout_width="match_parent"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_height="wrap_content"
                            android:layout_width="0dp"
                            android:orientation="vertical"
                            android:layout_weight="1">

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="14sp"
                                android:fontFamily="sans-serif-medium"
                                android:textColor="?attr/colorOnSurface"
                                android:text="Firebase 数据收集" />

                            <TextView
                                android:layout_height="wrap_content"
                                android:layout_width="match_parent"
                                android:textSize="12sp"
                                android:fontFamily="sans-serif"
                                android:textColor="?attr/colorOnSurfaceVariant"
                                android:layout_marginTop="2dp"
                                android:text="发送匿名使用情况和崩溃报告" />

                        </LinearLayout>

                        <com.google.android.material.materialswitch.MaterialSwitch
                            android:layout_height="wrap_content"
                            android:layout_width="wrap_content"
                            android:id="@+id/firebase_switch" />

                    </LinearLayout>

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                    android:layout_height="wrap_content"
                    android:layout_width="match_parent"
                    app:dividerColor="?attr/colorOutlineVariant"
                    app:dividerThickness="1dp" />

