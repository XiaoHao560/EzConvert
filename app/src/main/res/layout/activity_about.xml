<?xml version="1.0" encoding="utf-8"?>
<ScrollView
     xmlns:android="http://schemas.android.com/apk/res/android"
     xmlns:app="http://schemas.android.com/apk/res-auto"
     android:layout_height="match_parent"
     android:layout_width="match_parent"
     android:background="?attr/colorSurfaceContainerLowest"
     android:scrollbarStyle="outsideOverlay"
     android:fadeScrollbars="true">

    <LinearLayout
         android:layout_height="wrap_content"
         android:layout_width="match_parent"
         android:padding="16dp"
         android:orientation="vertical"
         android:id="@+id/scroll_content">

        <com.google.android.material.appbar.MaterialToolbar
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="16dp"
             android:background="@android:color/transparent"
             app:navigationIconTint="?attr/colorOnSurfaceVariant"
             app:title="关于"
             app:titleCentered="true"
             app:titleTextColor="?attr/colorPrimary"
             app:navigationIcon="@drawable/round_arrow_back"
             style="@style/Widget.Material3.Toolbar.Surface"
             app:navigationContentDescription="@string/tooltip_back"
             android:id="@+id/title_container">

        </com.google.android.material.appbar.MaterialToolbar>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="24dp"
                 android:orientation="vertical">

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:gravity="center"
                     android:orientation="vertical">

                    <ImageView
                         android:layout_height="64dp"
                         android:layout_width="64dp"
                         android:layout_marginBottom="8dp"
                         android:src="@mipmap/ic_launcher" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="24sp"
                         android:fontFamily="sans-serif-medium"
                         android:textColor="?attr/colorOnSurface"
                         android:text="EzConvert"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="wrap_content"
                         android:textSize="14sp"
                         android:fontFamily="sans-serif"
                         android:textColor="?attr/colorOnSurfaceVariant"
                         android:layout_marginTop="4dp"
                         android:id="@+id/version_text"
                         android:text="版本 0.9.0" />

                </LinearLayout>

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     android:textSize="14sp"
                     android:fontFamily="sans-serif"
                     android:textColor="?attr/colorOnSurface"
                     android:lineSpacingExtra="4dp"
                     android:text="一个简单易用的音视频转换工具，支持多种格式转换、压缩、裁剪等功能。" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:textSize="13sp"
                     android:fontFamily="sans-serif"
                     android:textColor="?attr/colorOnSurfaceVariant"
                     android:lineSpacingExtra="4dp"
                     android:text="开发者: XiaoHao\n邮箱: wzdmymzyl@163.com" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:layout_marginBottom="12dp"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="8dp"
                 android:orientation="vertical">

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     android:textSize="16sp"
                     android:fontFamily="sans-serif-medium"
                     android:textColor="?attr/colorOnSurface"
                     android:layout_marginTop="8dp"
                     android:layout_marginStart="16dp"
                     android:text="相关信息" />

                <LinearLayout
                     android:layout_height="72dp"
                     android:layout_width="match_parent"
                     android:paddingEnd="16dp"
                     android:background="?attr/selectableItemBackground"
                     android:gravity="center_vertical"
                     android:clickable="true"
                     android:orientation="horizontal"
                     android:paddingStart="16dp"
                     android:focusable="true"
                     android:id="@+id/source_code_item">

                    <FrameLayout
                         android:layout_height="40dp"
                         android:layout_width="40dp"
                         android:layout_marginEnd="16dp"
                         android:background="@drawable/circle_background_primary_container">

                        <ImageView
                             android:layout_height="24dp"
                             android:layout_width="24dp"
                             android:src="@drawable/round_code"
                             app:tint="?attr/colorPrimary"
                             android:layout_gravity="center" />

                    </FrameLayout>

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:orientation="vertical"
                         android:layout_weight="1">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="16sp"
                             android:fontFamily="sans-serif-medium"
                             android:textColor="?attr/colorOnSurface"
                             android:text="源代码" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="12sp"
                             android:fontFamily="sans-serif"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:text="查看GitHub上的源代码" />

                    </LinearLayout>

                    <ImageView
                         android:layout_height="24dp"
                         android:layout_width="24dp"
                         android:src="@drawable/round_arrow_forward"
                         app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     app:dividerColor="?attr/colorOutlineVariant"
                     app:dividerThickness="1dp"
                     android:layout_marginStart="72dp" />

                <LinearLayout
                     android:layout_height="72dp"
                     android:layout_width="match_parent"
                     android:paddingEnd="16dp"
                     android:background="?attr/selectableItemBackground"
                     android:gravity="center_vertical"
                     android:clickable="true"
                     android:orientation="horizontal"
                     android:paddingStart="16dp"
                     android:focusable="true"
                     android:id="@+id/feedback_item">

                    <FrameLayout
                         android:layout_height="40dp"
                         android:layout_width="40dp"
                         android:layout_marginEnd="16dp"
                         android:background="@drawable/circle_background_primary_container">

                        <ImageView
                             android:layout_height="24dp"
                             android:layout_width="24dp"
                             android:src="@drawable/message_alert_outline"
                             app:tint="?attr/colorPrimary"
                             android:layout_gravity="center" />

                    </FrameLayout>

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:orientation="vertical"
                         android:layout_weight="1">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="16sp"
                             android:fontFamily="sans-serif-medium"
                             android:textColor="?attr/colorOnSurface"
                             android:text="问题反馈" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="12sp"
                             android:fontFamily="sans-serif"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:text="在GitHub上报告问题" />

                    </LinearLayout>

                    <ImageView
                         android:layout_height="24dp"
                         android:layout_width="24dp"
                         android:src="@drawable/round_arrow_forward"
                         app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     app:dividerColor="?attr/colorOutlineVariant"
                     app:dividerThickness="1dp"
                     android:layout_marginStart="72dp" />

                <LinearLayout
                     android:layout_height="72dp"
                     android:layout_width="match_parent"
                     android:paddingEnd="16dp"
                     android:background="?attr/selectableItemBackground"
                     android:gravity="center_vertical"
                     android:clickable="true"
                     android:orientation="horizontal"
                     android:paddingStart="16dp"
                     android:focusable="true"
                     android:id="@+id/check_update_item">

                    <FrameLayout
                         android:layout_height="40dp"
                         android:layout_width="40dp"
                         android:layout_marginEnd="16dp"
                         android:background="@drawable/circle_background_primary_container">

                        <ImageView
                             android:layout_height="24dp"
                             android:layout_width="24dp"
                             android:src="@drawable/clock_outline"
                             app:tint="?attr/colorPrimary"
                             android:layout_gravity="center" />

                    </FrameLayout>

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:orientation="vertical"
                         android:layout_weight="1">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="16sp"
                             android:fontFamily="sans-serif-medium"
                             android:textColor="?attr/colorOnSurface"
                             android:text="检查更新" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:clickable="true"
                             android:textSize="12sp"
                             android:fontFamily="sans-serif"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:focusable="true"
                             android:id="@+id/update_status_text"
                             android:text="点击检查更新" />

                    </LinearLayout>

                    <ImageView
                         android:layout_height="24dp"
                         android:layout_width="24dp"
                         android:src="@drawable/round_arrow_forward"
                         app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:visibility="gone"
                     android:paddingEnd="16dp"
                     android:orientation="vertical"
                     android:paddingBottom="8dp"
                     android:paddingStart="64dp"
                     android:id="@+id/test_update_item"
                     android:paddingTop="8dp">

                    <com.google.android.material.divider.MaterialDivider
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="8dp"
                         app:dividerColor="?attr/colorOutlineVariant"
                         app:dividerThickness="1dp" />

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:background="?attr/selectableItemBackground"
                         android:clickable="true"
                         android:padding="8dp"
                         android:orientation="vertical"
                         android:focusable="true"
                         android:id="@+id/test_update_click_area">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="14sp"
                             android:fontFamily="sans-serif-medium"
                             android:textColor="?attr/colorPrimary"
                             android:text="强制拉取最新版" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="10sp"
                             android:fontFamily="sans-serif"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="2dp"
                             android:text="仅做测试版本更新" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:visibility="gone"
                     android:paddingEnd="16dp"
                     android:orientation="vertical"
                     android:paddingBottom="8dp"
                     android:paddingStart="64dp"
                     android:id="@+id/force_check_update_item"
                     android:paddingTop="8dp">

                    <com.google.android.material.divider.MaterialDivider
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="8dp"
                         app:dividerColor="?attr/colorOutlineVariant"
                         app:dividerThickness="1dp" />

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:background="?attr/selectableItemBackground"
                         android:clickable="true"
                         android:padding="8dp"
                         android:orientation="vertical"
                         android:focusable="true"
                         android:id="@+id/force_check_update_click_area">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="14sp"
                             android:fontFamily="sans-serif-medium"
                             android:textColor="?attr/colorPrimary"
                             android:text="强制检查更新" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="10sp"
                             android:fontFamily="sans-serif"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:layout_marginTop="2dp"
                             android:text="测试正式更新弹窗样式" />

                    </LinearLayout>

                </LinearLayout>

                <LinearLayout
                     android:layout_height="72dp"
                     android:layout_width="match_parent"
                     android:visibility="gone"
                     android:paddingEnd="16dp"
                     android:background="?attr/selectableItemBackground"
                     android:gravity="center_vertical"
                     android:clickable="true"
                     android:orientation="horizontal"
                     android:paddingStart="16dp"
                     android:focusable="true"
                     android:id="@+id/developer_item">

                    <FrameLayout
                         android:layout_height="40dp"
                         android:layout_width="40dp"
                         android:layout_marginEnd="16dp"
                         android:background="@drawable/circle_background_primary_container">

                        <ImageView
                             android:layout_height="24dp"
                             android:layout_width="24dp"
                             android:src="@drawable/bug_outline"
                             app:tint="?attr/colorTertiary"
                             android:layout_gravity="center" />

                    </FrameLayout>

                    <LinearLayout
                         android:layout_height="wrap_content"
                         android:layout_width="0dp"
                         android:orientation="vertical"
                         android:layout_weight="1">

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="16sp"
                             android:fontFamily="sans-serif-medium"
                             android:textColor="?attr/colorOnSurface"
                             android:text="开发者选项" />

                        <TextView
                             android:layout_height="wrap_content"
                             android:layout_width="match_parent"
                             android:textSize="12sp"
                             android:fontFamily="sans-serif"
                             android:textColor="?attr/colorOnSurfaceVariant"
                             android:text="调试工具与高级设置" />

                    </LinearLayout>

                    <ImageView
                         android:layout_height="24dp"
                         android:layout_width="24dp"
                         android:src="@drawable/round_arrow_forward"
                         app:tint="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             app:strokeColor="?attr/colorOutline"
             app:cardElevation="0dp"
             app:strokeWidth="1dp"
             app:cardBackgroundColor="@android:color/transparent"
             style="@style/Widget.Material3.CardView.Outlined"
             app:cardCornerRadius="12dp">

            <LinearLayout
                 android:layout_height="wrap_content"
                 android:layout_width="match_parent"
                 android:padding="24dp"
                 android:orientation="vertical">

                <LinearLayout
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:background="?attr/selectableItemBackground"
                     android:clickable="true"
                     android:orientation="vertical"
                     android:focusable="true"
                     android:id="@+id/license_item">

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:layout_marginBottom="8dp"
                         android:textSize="16sp"
                         android:fontFamily="sans-serif-medium"
                         android:textColor="?attr/colorOnSurface"
                         android:text="开源许可证"
                         android:textStyle="bold" />

                    <TextView
                         android:layout_height="wrap_content"
                         android:layout_width="match_parent"
                         android:textSize="13sp"
                         android:fontFamily="sans-serif"
                         android:textColor="?attr/colorOnSurface"
                         android:lineSpacingExtra="4dp"
                         android:text="EzConvert 使用 GPLv3 许可证开源\n© 2026 XiaoHao. 保留所有权利。" />

                </LinearLayout>

                <com.google.android.material.divider.MaterialDivider
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="16dp"
                     app:dividerColor="?attr/colorOutlineVariant"
                     app:dividerThickness="1dp"
                     android:layout_marginTop="16dp" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:layout_marginBottom="8dp"
                     android:textSize="16sp"
                     android:fontFamily="sans-serif-medium"
                     android:textColor="?attr/colorOnSurface"
                     android:text="鸣谢"
                     android:textStyle="bold" />

                <TextView
                     android:layout_height="wrap_content"
                     android:layout_width="match_parent"
                     android:textSize="13sp"
                     android:fontFamily="sans-serif"
                     android:textColor="?attr/colorOnSurface"
                     android:lineSpacingExtra="4dp"
                     android:text="• FFmpegKit - 音视频处理核心库\n• AndroidX - 现代Android支持库\n• Material Components - 界面组件" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <TextView
             android:layout_height="wrap_content"
             android:layout_width="match_parent"
             android:gravity="center"
             android:textSize="12sp"
             android:fontFamily="sans-serif"
             android:textColor="?attr/colorOnSurfaceVariant"
             android:layout_marginTop="16dp"
             android:text="感谢使用 EzConvert" />

    </LinearLayout>

</ScrollView>